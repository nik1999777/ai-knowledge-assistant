PORT=3001
WEB_ORIGIN=http://localhost:5173

# LLM provider: "ollama" (local, default) or "openai"
LLM_PROVIDER=ollama

# Ollama — used when LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_TEMPERATURE=0
OLLAMA_LLM_SEED=42

# OpenAI — used when LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_LLM_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small

# Optional: separate provider + model for query rewriting
# Best setup for development: Ollama for generation, OpenAI for rewriting
# REWRITE_PROVIDER=openai
# REWRITE_MODEL=gpt-4o-mini

QDRANT_URL=http://localhost:6333
POSTGRES_URL=postgresql://postgres:postgres@localhost:5434/ai_knowledge_assistant

RELEVANCE_THRESHOLD=0.714
DECLINE_SCORE_THRESHOLD=0.45
ANSWER_SCORE_THRESHOLD=0.47
DOMAIN_EVIDENCE_THRESHOLD=0.34
TOP_K=3
